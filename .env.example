# Supabase (local via CLI: http://127.0.0.1:54321 | production: Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# PostgreSQL direct connection (local: postgresql://postgres:postgres@127.0.0.1:54322/postgres)
DATABASE_URL=your_supabase_postgres_connection_string

# Email notifications (Resend — не потрібно для локальної розробки)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

NEXT_PUBLIC_APP_URL=http://localhost:3000
